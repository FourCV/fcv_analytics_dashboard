
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;600;700;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#293757;--navy-dark:#1c2740;--navy-dim:rgba(41,55,87,0.08);
  --orange:#F16623;--orange-dim:rgba(241,102,35,0.10);
  --sand:#E0CA81;--amber:#E1A238;--amber-dim:rgba(225,162,56,0.12);
  --teal:#40A295;--teal-lt:#95D4C5;--teal-dim:rgba(64,162,149,0.12);
  --bg:#eef0f4;--surface:#fff;--surface2:#f7f8fa;
  --border:rgba(41,55,87,0.10);--border2:#cdd3de;
  --text:#1c2740;--text2:#4a5568;--text3:#9aa5b4;
  --font:'DM Sans',system-ui,sans-serif;--mono:'DM Mono',monospace;
  --r:10px;--rlg:14px;
}
body{font-family:var(--font);font-size:13px;color:var(--text);background:var(--bg);padding:0;margin:0}

.dash{padding:20px 22px;display:flex;flex-direction:column;gap:16px}

/* HEADER */
.dash-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:2px}
.dash-title{font-weight:900;font-size:18px;color:var(--navy);letter-spacing:.2px}
.dash-sub{font-size:12px;color:var(--text3);margin-top:2px}
.header-right{display:flex;align-items:center;gap:10px}
.period-btn{padding:6px 14px;border-radius:6px;border:1px solid var(--border2);background:var(--surface);font-size:12px;font-family:var(--font);font-weight:600;color:var(--text2);cursor:pointer;transition:all .15s}
.period-btn.active{background:var(--navy);color:#fff;border-color:var(--navy)}
.live{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:20px;background:var(--teal-dim);color:#1a6b5f;font-size:11px;font-weight:700}
.live-dot{width:6px;height:6px;border-radius:50%;background:var(--teal);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.6;transform:scale(1.3)}}

/* KPI STRIP */
.kpi-strip{display:grid;grid-template-columns:repeat(7,1fr);gap:10px}
.kpi{background:var(--surface);border:1px solid var(--border);border-radius:var(--rlg);padding:14px 16px;position:relative;overflow:hidden;transition:box-shadow .15s}
.kpi:hover{box-shadow:0 4px 16px rgba(41,55,87,0.10)}
.kpi-accent{position:absolute;top:0;left:0;right:0;height:3px;border-radius:var(--rlg) var(--rlg) 0 0}
.kpi-lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.3px;color:var(--text3);margin-bottom:8px;line-height:1.3}
.kpi-val{font-family:var(--mono);font-size:18px;color:var(--text);line-height:1;font-weight:500}
.kpi-delta{font-size:10.5px;margin-top:5px;display:flex;align-items:center;gap:3px;font-weight:600}
.kpi-delta.up{color:#1a6b5f}
.kpi-delta.down{color:var(--orange)}
.kpi-delta.neutral{color:var(--text3)}
.arrow-up::before{content:'↑'}
.arrow-down::before{content:'↓'}

/* CHARTS ROW */
.charts-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.chart-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--rlg);padding:16px 18px}
.chart-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px}
.chart-title{font-weight:900;font-size:12px;text-transform:uppercase;letter-spacing:1.6px;color:var(--navy)}
.chart-sub{font-size:11px;color:var(--text3);margin-top:2px}
.chart-legend{display:flex;gap:12px;align-items:center}
.leg-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text2);font-weight:600}
.leg-dot{width:8px;height:8px;border-radius:50%}
.chart-wrap{position:relative;height:180px}

/* BOTTOM ROW */
.bottom-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px}
.inner-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--rlg);padding:16px 18px}
.inner-title{font-weight:900;font-size:11.5px;text-transform:uppercase;letter-spacing:1.6px;color:var(--navy);margin-bottom:12px}

/* BAR MINI */
.bar-row{display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid var(--border)}
.bar-row:last-child{border-bottom:none}
.bar-lbl{width:28px;font-size:11px;color:var(--text2);font-family:var(--mono)}
.bar-track{flex:1;height:5px;background:var(--surface2);border-radius:3px;overflow:hidden}
.bar-fill{height:100%;border-radius:3px}
.bar-val{font-family:var(--mono);font-size:10.5px;color:var(--text2);width:32px;text-align:right}

/* TAT TABLE */
.tat-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);font-size:12px}
.tat-row:last-child{border-bottom:none}
.tat-name{color:var(--text2);font-weight:600}
.tat-val{font-family:var(--mono);color:var(--navy);font-weight:500}
.tat-bar{flex:1;height:4px;background:var(--surface2);border-radius:2px;overflow:hidden;margin:0 10px}
.tat-fill{height:100%;border-radius:2px;background:var(--teal)}

/* DONUT WRAP */
.donut-wrap{position:relative;height:140px;display:flex;align-items:center;justify-content:center}
.donut-center{position:absolute;text-align:center;pointer-events:none}
.donut-center-val{font-family:var(--mono);font-size:20px;font-weight:500;color:var(--navy)}
.donut-center-lbl{font-size:10px;color:var(--text3);font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-top:2px}
.donut-legend{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:10px}
.donut-leg-item{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--text2)}
.donut-leg-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.donut-leg-val{font-family:var(--mono);font-size:11px;font-weight:500;margin-left:auto;color:var(--text)}
</style>

<div class="dash">

  <!-- HEADER -->
  <div class="dash-header">
    <div>
      <div class="dash-title">Analytics Dashboard</div>
      <div class="dash-sub">Four Corners Valuations · Real Estate Advisory Services</div>
    </div>
    <div class="header-right">
      <button class="period-btn" onclick="setPeriod(90,this)">90d</button>
      <button class="period-btn active" onclick="setPeriod(180,this)">6M</button>
      <button class="period-btn" onclick="setPeriod(365,this)">1Y</button>
      <div class="live"><span class="live-dot"></span>Live</div>
    </div>
  </div>

  <!-- KPI STRIP -->
  <div class="kpi-strip">
    <div class="kpi">
      <div class="kpi-accent" style="background:var(--orange)"></div>
      <div class="kpi-lbl">Order Volume</div>
      <div class="kpi-val" id="kv-orders">1,358</div>
      <div class="kpi-delta up"><span class="arrow-up"></span> 12.4% vs prior</div>
    </div>
    <div class="kpi">
      <div class="kpi-accent" style="background:var(--teal)"></div>
      <div class="kpi-lbl">Total Billed</div>
      <div class="kpi-val" id="kv-billed">$4.19M</div>
      <div class="kpi-delta up"><span class="arrow-up"></span> 8.7% vs prior</div>
    </div>
    <div class="kpi">
      <div class="kpi-accent" style="background:var(--navy)"></div>
      <div class="kpi-lbl">Total Revenue</div>
      <div class="kpi-val" id="kv-revenue">$3.56M</div>
      <div class="kpi-delta up"><span class="arrow-up"></span> 6.2% vs prior</div>
    </div>
    <div class="kpi">
      <div class="kpi-accent" style="background:var(--amber)"></div>
      <div class="kpi-lbl">Avg Price</div>
      <div class="kpi-val" id="kv-avg">$3,086</div>
      <div class="kpi-delta down"><span class="arrow-down"></span> 2.1% vs prior</div>
    </div>
    <div class="kpi">
      <div class="kpi-accent" style="background:var(--teal)"></div>
      <div class="kpi-lbl">Paid Amount</div>
      <div class="kpi-val" id="kv-paid">$3.84M</div>
      <div class="kpi-delta up"><span class="arrow-up"></span> 9.1% vs prior</div>
    </div>
    <div class="kpi">
      <div class="kpi-accent" style="background:var(--orange)"></div>
      <div class="kpi-lbl">Remaining</div>
      <div class="kpi-val" id="kv-remain">$361K</div>
      <div class="kpi-delta neutral">8.6% of billed</div>
    </div>
    <div class="kpi">
      <div class="kpi-accent" style="background:var(--sand)"></div>
      <div class="kpi-lbl">Turnaround (M)</div>
      <div class="kpi-val" id="kv-tat">18.4d</div>
      <div class="kpi-delta up"><span class="arrow-up"></span> −2.3d faster</div>
    </div>
  </div>

  <!-- CHARTS ROW -->
  <div class="charts-row">
    <div class="chart-card">
      <div class="chart-header">
        <div>
          <div class="chart-title">Order Volume</div>
          <div class="chart-sub" id="ov-sub">Showing 180 of 365 days</div>
        </div>
        <div class="chart-legend">
          <div class="leg-item"><div class="leg-dot" style="background:var(--teal)"></div>Orders</div>
        </div>
      </div>
      <div class="chart-wrap"><canvas id="chartOrders"></canvas></div>
    </div>
    <div class="chart-card">
      <div class="chart-header">
        <div>
          <div class="chart-title">Billed vs Revenue</div>
          <div class="chart-sub" id="br-sub">Showing 180 of 365 days</div>
        </div>
        <div class="chart-legend">
          <div class="leg-item"><div class="leg-dot" style="background:var(--navy)"></div>Billed</div>
          <div class="leg-item"><div class="leg-dot" style="background:var(--teal)"></div>Revenue</div>
        </div>
      </div>
      <div class="chart-wrap"><canvas id="chartBilled"></canvas></div>
    </div>
  </div>

  <!-- BOTTOM ROW -->
  <div class="bottom-row">

    <!-- Monthly Breakdown -->
    <div class="inner-card">
      <div class="inner-title">Monthly Order Volume</div>
      <div id="monthly-bars"></div>
    </div>

    <!-- TAT -->
    <div class="inner-card">
      <div class="inner-title">Turnaround Time by Type</div>
      <div class="tat-row"><span class="tat-name">Residential</span><div class="tat-bar"><div class="tat-fill" style="width:55%"></div></div><span class="tat-val">14.2d</span></div>
      <div class="tat-row"><span class="tat-name">Commercial</span><div class="tat-bar"><div class="tat-fill" style="width:78%;background:var(--amber)"></div></div><span class="tat-val">20.8d</span></div>
      <div class="tat-row"><span class="tat-name">Industrial</span><div class="tat-bar"><div class="tat-fill" style="width:90%;background:var(--orange)"></div></div><span class="tat-val">24.1d</span></div>
      <div class="tat-row"><span class="tat-name">Land / Lot</span><div class="tat-bar"><div class="tat-fill" style="width:40%"></div></div><span class="tat-val">10.7d</span></div>
      <div class="tat-row"><span class="tat-name">Multi-Family</span><div class="tat-bar"><div class="tat-fill" style="width:67%;background:var(--amber)"></div></div><span class="tat-val">17.9d</span></div>
      <div style="margin-top:12px;padding:10px 12px;background:var(--navy-dim);border-radius:var(--r);display:flex;justify-content:space-between;align-items:center">
        <span style="font-size:11px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:1px">Overall Avg</span>
        <span style="font-family:var(--mono);font-size:16px;font-weight:500;color:var(--navy)">18.4d</span>
      </div>
    </div>

    <!-- Paid vs Remaining Donut -->
    <div class="inner-card">
      <div class="inner-title">Paid vs Remaining</div>
      <div class="donut-wrap">
        <canvas id="chartDonut" style="max-height:130px;max-width:130px"></canvas>
        <div class="donut-center">
          <div class="donut-center-val">91.4%</div>
          <div class="donut-center-lbl">Collected</div>
        </div>
      </div>
      <div class="donut-legend">
        <div class="donut-leg-item"><div class="donut-leg-dot" style="background:var(--teal)"></div>Paid<span class="donut-leg-val">$3.84M</span></div>
        <div class="donut-leg-item"><div class="donut-leg-dot" style="background:var(--orange)"></div>Remaining<span class="donut-leg-val">$361K</span></div>
        <div class="donut-leg-item"><div class="donut-leg-dot" style="background:var(--navy)"></div>Billed<span class="donut-leg-val">$4.19M</span></div>
        <div class="donut-leg-item"><div class="donut-leg-dot" style="background:var(--amber)"></div>Avg Price<span class="donut-leg-val">$3,086</span></div>
      </div>
    </div>

  </div>
</div>

<script>
const months=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']

const dataByPeriod={
  90:{
    labels:['Dec-25','Jan-26','Feb-26','Mar-26'],
    orders:[86,81,74,128],
    billed:[250000,230000,210000,370000],
    revenue:[95000,40000,60000,120000],
    kpi:{orders:'369',billed:'$1.06M',revenue:'$315K',avg:'$2,873',paid:'$890K',remain:'$170K',tat:'19.2d'}
  },
  180:{
    labels:['Oct','Nov','Dec','Jan','Feb','Mar'],
    orders:[72,88,86,81,74,128],
    billed:[195000,238000,250000,230000,210000,370000],
    revenue:[72000,88000,95000,40000,60000,120000],
    kpi:{orders:'529',billed:'$1.49M',revenue:'$475K',avg:'$2,817',paid:'$1.24M',remain:'$250K',tat:'18.4d'}
  },
  365:{
    labels:['Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec','Jan','Feb','Mar'],
    orders:[58,91,96,83,77,68,72,88,86,81,74,128],
    billed:[155000,248000,262000,226000,210000,185000,195000,238000,250000,230000,210000,370000],
    revenue:[58000,91000,96000,83000,77000,68000,72000,88000,95000,40000,60000,120000],
    kpi:{orders:'1,358',billed:'$4.19M',revenue:'$3.56M',avg:'$3,086',paid:'$3.84M',remain:'$361K',tat:'18.4d'}
  }
}

let currentPeriod=180
let orderChart,billedChart,donutChart

function hexToRgb(hex){const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);return`${r},${g},${b}`}

function buildMonthlyBars(d){
  const max=Math.max(...d.orders)
  const colors=['var(--teal)','var(--teal)','var(--teal)','var(--amber)','var(--amber)','var(--orange)']
  const el=document.getElementById('monthly-bars')
  el.innerHTML=d.labels.map((lbl,i)=>`
    <div class="bar-row">
      <span class="bar-lbl">${lbl.substring(0,3)}</span>
      <div class="bar-track"><div class="bar-fill" style="width:${(d.orders[i]/max*100).toFixed(0)}%;background:${colors[i%colors.length]}"></div></div>
      <span class="bar-val">${d.orders[i]}</span>
    </div>`).join('')
}

function initCharts(period){
  const d=dataByPeriod[period]

  if(orderChart) orderChart.destroy()
  if(billedChart) billedChart.destroy()
  if(donutChart) donutChart.destroy()

  const baseOpts={
    responsive:true,maintainAspectRatio:false,
    plugins:{legend:{display:false},tooltip:{backgroundColor:'#293757',titleColor:'#fff',bodyColor:'rgba(255,255,255,0.75)',padding:10,cornerRadius:8,displayColors:false}},
    scales:{
      x:{grid:{display:false},ticks:{color:'#9aa5b4',font:{size:10.5,family:'DM Mono'}},border:{display:false}},
      y:{grid:{color:'rgba(41,55,87,0.06)'},ticks:{color:'#9aa5b4',font:{size:10.5,family:'DM Mono'}},border:{display:false}}
    },
    elements:{point:{radius:4,hoverRadius:6,borderWidth:2}}
  }

  orderChart=new Chart(document.getElementById('chartOrders'),{
    type:'line',
    data:{
      labels:d.labels,
      datasets:[{
        data:d.orders,
        borderColor:'#40A295',borderWidth:2.5,
        backgroundColor:'rgba(64,162,149,0.12)',
        fill:true,tension:.4,
        pointBackgroundColor:'#40A295',pointBorderColor:'#fff'
      }]
    },
    options:{...baseOpts,scales:{...baseOpts.scales,y:{...baseOpts.scales.y,beginAtZero:false}}}
  })

  billedChart=new Chart(document.getElementById('chartBilled'),{
    type:'line',
    data:{
      labels:d.labels,
      datasets:[
        {label:'Billed',data:d.billed,borderColor:'#293757',borderWidth:2.5,backgroundColor:'rgba(41,55,87,0.08)',fill:true,tension:.4,pointBackgroundColor:'#293757',pointBorderColor:'#fff'},
        {label:'Revenue',data:d.revenue,borderColor:'#40A295',borderWidth:2.5,backgroundColor:'rgba(64,162,149,0.10)',fill:true,tension:.4,pointBackgroundColor:'#40A295',pointBorderColor:'#fff'}
      ]
    },
    options:{...baseOpts,plugins:{...baseOpts.plugins,tooltip:{...baseOpts.plugins.tooltip,displayColors:true,callbacks:{label:(ctx)=>`${ctx.dataset.label}: $${(ctx.raw/1000).toFixed(0)}K`}}},scales:{...baseOpts.scales,y:{...baseOpts.scales.y,ticks:{...baseOpts.scales.y.ticks,callback:(v)=>'$'+(v/1000).toFixed(0)+'K'}}}}
  })

  donutChart=new Chart(document.getElementById('chartDonut'),{
    type:'doughnut',
    data:{
      labels:['Paid','Remaining'],
      datasets:[{data:[91.4,8.6],backgroundColor:['#40A295','#F16623'],borderWidth:0,hoverOffset:4}]
    },
    options:{responsive:true,maintainAspectRatio:false,cutout:'72%',plugins:{legend:{display:false},tooltip:{backgroundColor:'#293757',titleColor:'#fff',bodyColor:'rgba(255,255,255,0.75)',padding:8,cornerRadius:8,callbacks:{label:(ctx)=>` ${ctx.label}: ${ctx.raw}%`}}}}
  })

  buildMonthlyBars(d)
  const kpi=d.kpi
  document.getElementById('kv-orders').textContent=kpi.orders
  document.getElementById('kv-billed').textContent=kpi.billed
  document.getElementById('kv-revenue').textContent=kpi.revenue
  document.getElementById('kv-avg').textContent=kpi.avg
  document.getElementById('kv-paid').textContent=kpi.paid
  document.getElementById('kv-remain').textContent=kpi.remain
  document.getElementById('kv-tat').textContent=kpi.tat
  document.getElementById('ov-sub').textContent=`Showing ${period} of 365 days`
  document.getElementById('br-sub').textContent=`Showing ${period} of 365 days`
}

function setPeriod(p,btn){
  currentPeriod=p
  document.querySelectorAll('.period-btn').forEach(b=>b.classList.remove('active'))
  btn.classList.add('active')
  initCharts(p)
}

initCharts(180)
</script>
